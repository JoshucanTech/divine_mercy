# Database Connection
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/voting_platform
DATABASE_URL="postgresql://user:password@localhost:5432/voting_platform"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# NextAuth URL - Update for production
NEXTAUTH_URL="http://localhost:3000"

# Flutterwave Payment Integration
# Get these from https://dashboard.flutterwave.com/settings/apis
# Leave empty to use mock payment mode
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
