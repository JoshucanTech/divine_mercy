generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contestant {
  id        String   @id @default(cuid())
  name      String
  image     String?
  voteCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([voteCount])
  @@map("contestant")
}

model Transaction {
  id           String   @id @default(cuid())
  contestantId String
  voterEmail   String
  voterName    String?
  amount       Float
  currency     String   @default("NGN")
  flutterRef   String?  @unique
  status       String   @default("pending")
  voteApplied  Boolean  @default(false)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([flutterRef])
  @@index([status])
  @@index([contestantId])
  @@map("transaction")
}

model Settings {
  id           String  @id @unique @default("singleton")
  voteCost     Float   @default(100)
  currency     String  @default("NGN")
  votingActive Boolean @default(true)

  @@map("settings")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_user")
}
